# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/task_system?schema=public
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=task_system

# Cache & Queue (Redis)
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT Authentication
JWT_SECRET=super_secret_key_change_me_in_production
JWT_EXPIRES_IN=3600

# Email Service (e.g., Mailtrap/SendGrid)
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USER=your_user
EMAIL_PASS=your_pass

# Server Configuration
PORT=3000
HOST=127.0.0.1
NODE_ENV=development
